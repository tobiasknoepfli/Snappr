<Window x:Class="Snappr.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Snappr"
        xmlns:vm="clr-namespace:Snappr.ViewModels"
        xmlns:conv="clr-namespace:Snappr.Converters"
        xmlns:models="clr-namespace:Snappr.Models"
        mc:Ignorable="d"
        Title="Snappr" Height="800" Width="1400"
        Icon="/Assets/favicon.ico"
        Background="#0E0E0E" Foreground="#FFFFFF"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True"
        BorderThickness="1" BorderBrush="#222">

    
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <conv:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>

        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#0078D4"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <Style x:Key="DarkPanel" TargetType="Border">
            <Setter Property="Background" Value="#161616"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="5"/>
        </Style>

        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="2"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="4"/>
                </Style>
            </Style.Resources>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3D3D3D"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="#161616"/>
            <Setter Property="Width" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid x:Name="Bg" Background="{TemplateBinding Background}" SnapsToDevicePixels="true">
                            <Track x:Name="PART_Track" IsDirectionReversed="true" IsEnabled="{TemplateBinding IsEnabled}">
                                <Track.Thumb>
                                    <Thumb x:Name="Thumb">
                                        <Thumb.Style>
                                            <Style TargetType="Thumb">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Thumb">
                                                            <Border Background="#333" CornerRadius="5" Margin="2"/>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Thumb">
                                                                    <Border Background="#444" CornerRadius="5" Margin="1"/>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Thumb.Style>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>


    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/> <!-- Custom Title Bar -->
            <RowDefinition Height="*"/>    <!-- Main Content -->
        </Grid.RowDefinitions>

        <!-- Custom Title Bar -->
        <Border Grid.Row="0" Background="#161616" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <Grid.Resources>
                    <Style x:Key="TitleBarButton" TargetType="Button">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="#888"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Width" Value="46"/>
                        <Setter Property="Height" Value="32"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#333"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>

                    <Style x:Key="CloseButton" TargetType="Button" BasedOn="{StaticResource TitleBarButton}">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E81123"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Resources>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="10,0">
                    <Image Source="/Assets/favicon.ico" Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="SNAPPR" Foreground="#0078D4" FontWeight="Black" VerticalAlignment="Center" FontSize="11"/>

                </StackPanel>

                <!-- Drag region -->
                <Grid Grid.Column="1" Background="Transparent"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="−" Click="Minimize_Click" Style="{StaticResource TitleBarButton}"/>
                    <Button Content="▢" Click="Maximize_Click" Style="{StaticResource TitleBarButton}"/>
                    <Button Content="✕" Click="Close_Click" Style="{StaticResource CloseButton}"/>
                </StackPanel>
            </Grid>
        </Border>


        <Grid Grid.Row="1" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Header / Settings -->

            <RowDefinition Height="*"/>    <!-- Main Body -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Style="{StaticResource DarkPanel}" Margin="5,5,5,10">
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <Image Source="/Assets/logo.png" Width="30" Height="30" Margin="0,0,15,0"/>
                    <TextBlock Text="Snappr" FontSize="22" FontWeight="Bold" VerticalAlignment="Center" Foreground="#0078D4" Margin="0,0,30,0"/>
                    
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="SOURCE FOLDER" FontSize="10" Foreground="#666" FontWeight="Bold"/>
                        <TextBlock Text="{Binding SourceFolder}" FontSize="13" Foreground="#DDD"/>
                    </StackPanel>
                </StackPanel>

                <Button HorizontalAlignment="Right" Content="Change Folder" Padding="20,8" 
                        Command="{Binding SelectFolderCommand}" Style="{StaticResource ModernButton}"/>
            </Grid>
        </Border>

        <!-- Main Layout -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/> <!-- Left: Search & Tree -->
                <ColumnDefinition Width="*"/>   <!-- Main: Gallery -->
                <ColumnDefinition Width="300"/> <!-- Right: Export -->
            </Grid.ColumnDefinitions>

            <!-- LEFT PANEL -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Search -->
                    <RowDefinition Height="*"/>    <!-- Folder Tree -->
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource DarkPanel}">
                    <StackPanel>
                        <TextBlock Text="SEARCH &amp; FILTERS" Style="{StaticResource SectionHeader}"/>
                        <Grid>
                            <TextBox x:Name="SearchBox" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                                     Background="#222" Foreground="White" BorderThickness="1" BorderBrush="#333" 
                                     Padding="10,10,35,10" Margin="0,5">
                                <TextBox.ToolTip>
                                    <ToolTip Background="#222" Foreground="White" BorderBrush="#333">
                                        <StackPanel>
                                            <TextBlock Text="Search Operators:" FontWeight="Bold" Margin="0,0,0,5"/>
                                            <TextBlock Text="• Comma (,) : AND (both keywords)"/>
                                            <TextBlock Text="• Slash (/) : OR (either keyword)"/>
                                            <TextBlock Text="• Asterisk (*) : Wildcard (any text)"/>
                                            <TextBlock Text="• gps=location : Search by City/Place"/>
                                            <TextBlock Text="• name=text : Search exclusively in filename"/>
                                            <TextBlock Text="• folder=text : Search in folder path"/>
                                            <TextBlock Text="• date=YYYY-MM-DD / month=N / year=YYYY"/>
                                            <TextBlock Text="• datebefore=D / dateafter=D / datebetween=D-D"/>
                                            <TextBlock Text="• &quot;keyword&quot; : Exact match (case insensitive)"/>
                                            <TextBlock Text="Example: year=2023, folder=italy, &quot;DSC001.jpg&quot;" Margin="0,5,0,0" Foreground="#0078D4"/>




                                        </StackPanel>
                                    </ToolTip>
                                </TextBox.ToolTip>
                                <TextBox.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="4"/>
                                    </Style>
                                </TextBox.Resources>
                            </TextBox>
                            
                            <Button Command="{Binding ClearSearchCommand}" 
                                    Content="✕" 
                                    FontSize="14"
                                    Foreground="#AAA"
                                    Background="Transparent" 
                                    BorderThickness="0"
                                    HorizontalAlignment="Right" 
                                    VerticalAlignment="Center"
                                    Margin="0,0,10,0"
                                    Cursor="Hand"
                                    Visibility="{Binding SearchText, FallbackValue=Collapsed, Converter={StaticResource NullToVisibilityConverter}}">

                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Foreground" Value="White"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>


                        </Grid>

                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Style="{StaticResource DarkPanel}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="SUBFOLDERS" Style="{StaticResource SectionHeader}"/>
                        
                        <TreeView Grid.Row="1" ItemsSource="{Binding FolderTree}" Background="Transparent" BorderThickness="0"
                                  SelectedItemChanged="TreeView_SelectedItemChanged">

                            <TreeView.ItemContainerStyle>
                                <Style TargetType="TreeViewItem">
                                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#0078D4"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TreeView.ItemContainerStyle>
                            <TreeView.ItemTemplate>

                                <HierarchicalDataTemplate DataType="{x:Type models:FolderNode}" ItemsSource="{Binding SubFolders}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📁" Margin="0,0,5,0" Foreground="#0078D4"/>
                                        <TextBlock Text="{Binding Name}"/>
                                    </StackPanel>
                                </HierarchicalDataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>
                    </Grid>
                </Border>

            </Grid>

            <!-- MAIN AREA: GALLERY -->
            <Border Grid.Column="1" Style="{StaticResource DarkPanel}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="5,0,0,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding SelectedCount}" Foreground="#0078D4" FontWeight="Bold" FontSize="16"/>
                            <TextBlock Text=" pictures selected" Foreground="#888" VerticalAlignment="Bottom" Margin="5,0,0,2" Visibility="{Binding HasSelection, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            <TextBlock Text="{Binding FilteredImages.Count}" Foreground="#0078D4" FontWeight="Bold" FontSize="16" Margin="10,0,0,0" Visibility="{Binding HasSelection, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Inverted}"/>
                            <TextBlock Text=" pictures total" Foreground="#888" VerticalAlignment="Bottom" Margin="5,0,0,2" Visibility="{Binding HasSelection, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Inverted}"/>
                        </StackPanel>
                        <!-- Search Progress Wheel -->
                        <ProgressBar IsIndeterminate="True" Height="2" Background="Transparent" Foreground="#0078D4" BorderThickness="0" Margin="0,5,0,0"
                                     Visibility="{Binding IsDeepScanning, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </StackPanel>

                    
                    <TextBlock Grid.Row="1" Text="No images found" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#444" FontSize="20"
                               Visibility="{Binding FilteredImages.Count, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Inverted}"/>

                    
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">


                        <ListBox ItemsSource="{Binding FilteredImages}" SelectedItem="{Binding SelectedImage}"
                                 SelectionMode="Extended"
                                 Background="Transparent" BorderThickness="0"
                                 HorizontalContentAlignment="Stretch"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">


                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel ItemWidth="160" ItemHeight="160" Margin="10"/>
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border x:Name="ItemBorder" Margin="5" Background="#1E1E1E" CornerRadius="8" Padding="5" Cursor="Hand" BorderThickness="2" BorderBrush="Transparent">
                                        <Border.InputBindings>
                                            <MouseBinding MouseAction="LeftDoubleClick" Command="{Binding DataContext.OpenPreviewCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                        </Border.InputBindings>
                                        <Grid>
                                            <Image Stretch="UniformToFill">
                                                <Image.Source>
                                                    <BitmapImage UriSource="{Binding FilePath}" 
                                                                 DecodePixelWidth="160" 
                                                                 CacheOption="OnLoad"
                                                                 CreateOptions="DelayCreation"/>
                                                </Image.Source>
                                            </Image>

                                            <Border VerticalAlignment="Bottom" Background="#AA000000" Padding="5">
                                                <TextBlock Text="{Binding FileName}" Foreground="White" FontSize="10" TextTrimming="CharacterEllipsis"/>
                                            </Border>
                                            
                                            <CheckBox IsChecked="{Binding IsSelected}" Visibility="Collapsed"/>
                                        </Grid>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                            <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#0078D4"/>
                                            <Setter TargetName="ItemBorder" Property="Background" Value="#2A2A2A"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <ContentPresenter />
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- RIGHT PANEL: EXPORT -->
            <Border Grid.Column="2" Style="{StaticResource DarkPanel}">
                <Grid Visibility="{Binding SelectedImage, Converter={StaticResource NullToVisibilityConverter}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Title -->
                        <RowDefinition Height="Auto"/> <!-- Metadata -->
                        <RowDefinition Height="*"/>    <!-- Keywords -->
                        <RowDefinition Height="Auto"/> <!-- Export -->
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="IMAGE DETAILS" Style="{StaticResource SectionHeader}"/>
                    
                    <StackPanel Grid.Row="1" Margin="0,0,0,20">
                        <TextBlock Text="{Binding SelectedImage.FileName}" FontSize="18" FontWeight="Bold" Foreground="#DDD" TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding SelectedImage.DateTaken}" Foreground="#666" Margin="0,5"/>
                    </StackPanel>

                    <ScrollViewer Grid.Row="2">
                        <StackPanel>
                            <TextBlock Text="KEYWORDS" FontSize="11" Foreground="#0078D4" FontWeight="Bold" Margin="0,0,0,5"/>
                            <TextBlock Text="{Binding SelectedImage.DisplayKeywords}" TextWrapping="Wrap" Foreground="#AAA"/>
                            
                            <TextBlock Text="PATH" FontSize="11" Foreground="#0078D4" FontWeight="Bold" Margin="0,15,0,5"/>
                            <TextBlock Text="{Binding SelectedImage.FolderPath}" TextWrapping="Wrap" Foreground="#AAA" FontSize="10"/>
                            
                            <Button Content="Show in Explorer" Style="{StaticResource ModernButton}" Command="{Binding OpenInExplorerCommand}" Margin="0,15,0,0"/>
                        </StackPanel>
                    </ScrollViewer>

                    <Border Grid.Row="3" Background="#1A1A1A" CornerRadius="8" Padding="15" Margin="0,20,0,0">
                        <StackPanel>
                            <TextBlock Text="EXPORT AS" Style="{StaticResource SectionHeader}" HorizontalAlignment="Center"/>
                            <UniformGrid Columns="2">
                                <Button Content="Full Size" Style="{StaticResource ModernButton}" Command="{Binding ExportCommand}" CommandParameter="Full"/>
                                <Button Content="Half Size" Style="{StaticResource ModernButton}" Command="{Binding ExportCommand}" CommandParameter="Half"/>
                                <Button Content="Quarter" Style="{StaticResource ModernButton}" Command="{Binding ExportCommand}" CommandParameter="Quarter"/>
                                <Button Content="Custom %" Style="{StaticResource ModernButton}" Command="{Binding ExportCommand}" CommandParameter="Custom"/>
                            </UniformGrid>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- FULL IMAGE OVERLAY -->
        <Border Grid.RowSpan="2" Background="#F0000000" Visibility="{Binding IsFullImageMode, Converter={StaticResource BooleanToVisibilityConverter}}" Panel.ZIndex="100">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <Button HorizontalAlignment="Left" Content="← Close Preview" Style="{StaticResource ModernButton}" Command="{Binding ClosePreviewCommand}" Margin="20"/>
                <TextBlock Grid.Row="0" HorizontalAlignment="Center" Text="{Binding SelectedImage.FileName}" FontSize="20" VerticalAlignment="Center"/>

                <Image Grid.Row="1" Source="{Binding SelectedImage.FilePath}" Stretch="Uniform" Margin="40"/>
            </Grid>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.RowSpan="2" Background="#A0000000" Cursor="Arrow" Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}" Panel.ZIndex="200">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" Foreground="#0078D4" Background="#333"/>
                <TextBlock Text="{Binding StatusMessage}" Margin="0,10,0,0" HorizontalAlignment="Center" FontWeight="Bold"/>
            </StackPanel>
        </Border>
    </Grid>
</Grid>
</Window>
