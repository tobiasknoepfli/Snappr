<Window x:Class="Snappr.Views.FolderPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Folder" Height="600" Width="800"
        WindowStartupLocation="CenterOwner"
        Background="#121212" Foreground="#FFFFFF"
        WindowStyle="None" AllowsTransparency="True"
        BorderThickness="1" BorderBrush="#333">
    
    <Window.Resources>
        <Style x:Key="PickerButton" TargetType="Button">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="5"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="6"/>
                </Style>
            </Style.Resources>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3D3D3D"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource PickerButton}">
            <Setter Property="Background" Value="#0078D4"/>
        </Style>
    </Window.Resources>

    <Grid Margin="2">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Title -->
            <RowDefinition Height="Auto"/> <!-- Toolbar -->
            <RowDefinition Height="*"/>    <!-- Content -->
            <RowDefinition Height="Auto"/> <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <Border Grid.Row="0" Background="#1E1E1E" Padding="15,10" MouseLeftButtonDown="Border_MouseLeftButtonDown">
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <Image Source="/Assets/logo.png" Width="20" Height="20" Margin="0,0,10,0"/>
                    <TextBlock Text="SNAPP-PICKER" FontWeight="Bold" Foreground="#888" VerticalAlignment="Center" FontSize="12"/>
                </StackPanel>
                <Button Content="✕" HorizontalAlignment="Right" Background="Transparent" Foreground="White" BorderThickness="0" Click="CancelButton_Click" Cursor="Hand" Width="30"/>
            </Grid>
        </Border>

        <!-- Toolbar (Address & Nav) -->
        <Grid Grid.Row="1" Background="#1A1A1A">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <StackPanel Orientation="Horizontal">
                <Button Content="←" Style="{StaticResource PickerButton}" Click="BackButton_Click" IsEnabled="{Binding CanGoBack}"/>
                <Button Content="↑" Style="{StaticResource PickerButton}" Click="UpButton_Click"/>
            </StackPanel>
            
            <Border Grid.Column="1" Background="#252525" CornerRadius="4" Margin="10,0,0,0" Padding="8,5">
                <TextBox x:Name="PathTextBox" Text="{Binding CurrentPath, UpdateSourceTrigger=PropertyChanged}" 
                         Background="Transparent" Foreground="White" BorderThickness="0" VerticalAlignment="Center"
                         KeyDown="PathTextBox_KeyDown"/>
            </Border>
        </Grid>

        <!-- Main Content Area -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Navigation Sidebar (Quick Access / Drives) -->
            <Border Grid.Column="0" Background="#181818" BorderBrush="#333" BorderThickness="0,0,1,0">
                <ScrollViewer>
                    <StackPanel Margin="10">
                        <TextBlock Text="QUICK ACCESS" FontSize="10" FontWeight="Bold" Foreground="#555" Margin="0,0,0,10"/>
                        <ListBox x:Name="QuickAccessList" Background="Transparent" BorderThickness="0" Foreground="White" SelectionChanged="QuickAccessList_SelectionChanged">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}" Margin="5"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        
                        <TextBlock Text="DRIVES" FontSize="10" FontWeight="Bold" Foreground="#555" Margin="0,20,0,10"/>
                        <ListBox x:Name="DrivesList" Background="Transparent" BorderThickness="0" Foreground="White" SelectionChanged="DrivesList_SelectionChanged">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}" Margin="5"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- File/Folder View -->
            <ListBox Grid.Column="1" x:Name="ItemListBox" Background="Transparent" Foreground="White" BorderThickness="0" 
                     MouseDoubleClick="ItemListBox_MouseDoubleClick" SelectionChanged="ItemListBox_SelectionChanged">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="5">
                            <TextBlock Text="{Binding Icon}" Margin="0,0,10,0" Foreground="{Binding IconColor}"/>
                            <TextBlock Text="{Binding Name}" Foreground="White"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

        </Grid>

        <!-- Footer -->
        <Border Grid.Row="3" Background="#1E1E1E" Padding="15,10">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <TextBlock Text="Current Folder: " Foreground="#888"/>
                    <TextBlock Text="{Binding TargetFolder}" Foreground="White" FontWeight="Bold"/>
                </StackPanel>
                
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancel" Style="{StaticResource PickerButton}" Click="CancelButton_Click"/>
                    <Button Content="Select folder" Style="{StaticResource AccentButton}" Click="SelectButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
